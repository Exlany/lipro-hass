#!/usr/bin/env bash
# Run critical diagnostics tests before push.

set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

if ! command -v uv >/dev/null 2>&1; then
    echo "Error: uv is required for pre-push tests. Install uv and retry."
    exit 1
fi

echo "Running diagnostics gate tests with uv..."
uv run pytest -q \
  tests/test_diagnostics.py::TestAsyncGetConfigEntryDiagnostics::test_collects_and_redacts_diagnostics \
  tests/test_diagnostics.py::TestAsyncGetConfigEntryDiagnostics::test_handles_no_devices \
  tests/test_diagnostics.py::TestAsyncGetConfigEntryDiagnostics::test_diagnostics_snapshot
