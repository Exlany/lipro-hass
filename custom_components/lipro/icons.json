        "state": {
          "on": "mdi:lan-connect",
          "off": "mdi:lan-disconnect"
        }
      },
      "motion": {
        "default": "mdi:motion-sensor",
        "state": {
          "on": "mdi:motion-sensor",
          "off": "mdi:motion-sensor-off"
        }
      },
      "door": {
        "default": "mdi:door",
        "state": {
          "on": "mdi:door-open",
          "off": "mdi:door-closed"
        }
      },
      "light": {
        "default": "mdi:brightness-6",
        "state": {
          "on": "mdi:brightness-7",
          "off": "mdi:brightness-5"
        }
      },
      "battery": {
        "default": "mdi:battery",
        "state": {
          "on": "mdi:battery-alert",
          "off": "mdi:battery"
        }
      }
    },
    "fan": {
      "fan": {
        "default": "mdi:fan",
        "state": {
          "on": "mdi:fan",
          "off": "mdi:fan-off"
        }
      },
      "ventilation_fan": {
        "default": "mdi:fan",
        "state": {
          "on": "mdi:fan",
          "off": "mdi:fan-off"
        }
      }
    },
    "cover": {
      "curtain": {
        "default": "mdi:curtains",
        "state": {
