      "outlet": {
        "default": "mdi:power-socket-eu",
        "state": {
          "on": "mdi:power-plug",
          "off": "mdi:power-plug-off"
        }
      },
      "fade": {
        "default": "mdi:transition"
      },
      "sleep_aid": {
        "default": "mdi:sleep"
      },
      "wake_up": {
        "default": "mdi:weather-sunny"
